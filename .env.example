# ============================================================
# Quill — example environment variables
# ============================================================
# This file is COMMITTED to the repo. It documents what env
# vars exist. NEVER put real secrets here. Copy to `.env` and
# fill in values locally; `.env` is gitignored.
# ============================================================

# --- LLM providers (Phase 2 will introduce these) ---
# Google AI Studio (Gemini) — free tier, get a key at:
#   https://aistudio.google.com/apikey
# QUILL_GEMINI_API_KEY=

# Groq (free tier, fast Llama 3.3 70B) — fallback provider
#   https://console.groq.com/keys
# QUILL_GROQ_API_KEY=

# --- Code signing (Phase 8 only) ---
# Apple Developer ID for code signing the .dmg
# APPLE_ID=
# APPLE_TEAM_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_SIGNING_IDENTITY=
